<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="application.MainController"
            prefHeight="500.0" prefWidth="700.0">

    <Label text="Activity Invitation System"
           layoutX="270" layoutY="150"/>

    <Label text="Welcome !"
           layoutX="310" layoutY="190"/>

    <Button fx:id="createBtn" text="Create Activity"
            layoutX="180" layoutY="300"
            onAction="#handleCreateActivity"/>

    <Button fx:id="joinBtn" text="Join Activity"
            layoutX="450" layoutY="300"
            onAction="#handleJoinActivity"/>
            
    <Button fx:id="editBtn" text="Edit Activity"
            layoutX="315" layoutY="300"
            onAction="#handleEditActivity"/>

</AnchorPane>