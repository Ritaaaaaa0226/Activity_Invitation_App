<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="application.ActivityListController">
            
    <Button layoutX="30" layoutY="20" onAction="#handleBack" prefWidth="80" text="Back" />
    
    <Label layoutX="270" layoutY="20" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Available Activities" />
   
    <TableView fx:id="activityTable" layoutX="40.0" layoutY="62.0" prefHeight="350.0" prefWidth="640">
        <columns>
            <TableColumn fx:id="colName" prefWidth="102.0" text="Activity" />
         <TableColumn fx:id="colDate" prefWidth="129.0" text="Date" />
            <TableColumn fx:id="colOrganizer" prefWidth="189.0" text="Organizer" />
            <TableColumn fx:id="colTimeSlot" prefWidth="110" text="TimeSlot" />
            <TableColumn fx:id="colLocation" prefWidth="120" text="Location" />
            <TableColumn fx:id="colStatus" prefWidth="80" text="Status" />
        </columns>
    </TableView>

    <Button layoutX="300" layoutY="430" onAction="#handleJoin" prefWidth="120" text="Join Activity" />
            
    <Label fx:id="messageLabel" layoutX="220" layoutY="470" style="-fx-text-fill: green;" />

</AnchorPane>
