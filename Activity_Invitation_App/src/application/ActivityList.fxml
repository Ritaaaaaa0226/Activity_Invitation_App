<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="application.ActivityListController"
            prefHeight="500.0" prefWidth="700.0">

    <Label text="Available Activities"
           layoutX="270" layoutY="20"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TableView fx:id="activityTable"
               layoutX="30" layoutY="60"
               prefWidth="640" prefHeight="350">
        <columns>
            <TableColumn fx:id="colName"      text="Activity"   prefWidth="160"/>
            <TableColumn fx:id="colOrganizer" text="Organizer"  prefWidth="100"/>
            <TableColumn fx:id="colDate"      text="Date"       prefWidth="110"/>
            <TableColumn fx:id="colLocation"  text="Location"   prefWidth="120"/>
            <TableColumn fx:id="colStatus"    text="Status"     prefWidth="80"/>
        </columns>
    </TableView>

    <Button text="Join Activity"
            layoutX="300" layoutY="430"
            prefWidth="120"
            onAction="#handleJoin"/>

    <Label fx:id="messageLabel"
           layoutX="220" layoutY="470"
           style="-fx-text-fill: green;"/>

</AnchorPane>