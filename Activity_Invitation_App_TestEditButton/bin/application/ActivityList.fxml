<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="application.ActivityListController">

    <Label layoutX="270" layoutY="20" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Available Activities" />

    <TableView fx:id="activityTable" layoutX="30" layoutY="60" prefHeight="350" prefWidth="640">
        <columns>
            <TableColumn fx:id="colName" prefWidth="160" text="Activity" />
            <TableColumn fx:id="colOrganizer" prefWidth="100" text="Organizer" />
            <TableColumn fx:id="colDate" prefWidth="110" text="Date" />
            <TableColumn fx:id="colLocation" prefWidth="120" text="Location" />
            <TableColumn fx:id="colStatus" prefWidth="80" text="Status" />
        </columns>
    </TableView>

    <Button layoutX="411.0" layoutY="431.0" onAction="#handleJoin" prefWidth="120" text="Join Activity" />

    <Label fx:id="messageLabel" layoutX="220" layoutY="470" style="-fx-text-fill: green;" />
   <Button layoutX="216.0" layoutY="431.0" onAction="#handleEditActivity" mnemonicParsing="false" text="Edit Activity"  />

</AnchorPane>
